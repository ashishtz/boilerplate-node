# Application
NODE_ENV=development
PORT=4200
SERVER_URL=http://localhost:4200
# Comma separated list of origins allowed by CORS, e.g. http://localhost:5173,https://app.example.com
# When empty: development allows every origin, production refuses cross-origin browser requests.
ALLOWED_ORIGINS=
# Set to true when running behind a reverse proxy / load balancer so client
# IPs (used by the rate limiter) are read from X-Forwarded-For.
TRUST_PROXY=false

# Logging
# One of: fatal, error, warn, info, debug, trace, silent
LOG_LEVEL=info
# Logs every SQL query with its duration (requires LOG_LEVEL=debug or lower).
ENABLE_QUERY_LOG=false

# Database
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USERNAME=root
DATABASE_PASSWORD=secret
DATABASE_NAME=boilerplate
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Auth
AUTH_TOKEN_EXPIRY=7d
REMEMBER_TOKEN_EXPIRY=30d
# Passphrase protecting the RSA private key (used by generate:keys and at signing time).
JWT_PASSPHRASE=change-me-to-a-strong-passphrase
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
# Secret for single purpose tokens (email verification, password reset links).
MAIL_TOKEN_SECRET=change-me-to-a-long-random-string
BCRYPT_SALT_ROUNDS=12

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

{
	"name": "boilerplate-node",
	"version": "2.0.0",
	"description": "Production-grade Express.js + TypeScript boilerplate with Objection.js and MySQL",
	"main": "dist/index.js",
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"clean": "rm -rf dist coverage",
		"dev": "tsx watch src/index.ts",
		"start": "node dist/index.js",
		"typecheck": "tsc --noEmit",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "vitest run",
		"test:watch": "vitest",
		"generate:keys": "tsx scripts/generate-keys.ts",
		"new-migration": "knex migrate:make",
		"migrate": "knex migrate:latest",
		"rollback": "knex migrate:rollback",
		"prepare": "husky"
	},
	"author": "Ashish Patel",
	"license": "MIT",
	"dependencies": {
		"bcrypt": "^6.0.0",
		"cors": "^2.8.6",
		"dotenv": "^17.4.2",
		"express": "^5.2.1",
		"express-rate-limit": "^8.5.2",
		"helmet": "^8.2.0",
		"joi": "^18.2.3",
		"jsonwebtoken": "^9.0.3",
		"knex": "^3.3.0",
		"mysql2": "^3.22.5",
		"objection": "^3.1.5",
		"pino": "^10.3.1",
		"pino-http": "^11.0.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/bcrypt": "^6.0.0",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^26.1.0",
		"@types/supertest": "^6.0.3",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.7.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"pino-pretty": "^13.1.3",
		"prettier": "^3.9.4",
		"supertest": "^7.2.2",
		"tsx": "^4.22.4",
		"typescript": "^7.0.2",
		"typescript-eslint": "^8.62.1",
		"vitest": "^4.1.9"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"lint-staged": {
		"*.{ts,js,mjs}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,md,yml,yaml}": [
			"prettier --write"
		]
	}
}
